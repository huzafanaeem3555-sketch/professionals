// Migrated to declarative plugin application. This file replaces the old
// imperative application of Flutter's app_plugin_loader.gradle.
// If you need to restore the original, see settings.gradle.bak

pluginManagement {
	def properties = new Properties()
	file("local.properties").withReader('UTF-8') { reader -> properties.load(reader) }
	def flutterSdkPath = properties.getProperty('flutter.sdk')
	assert flutterSdkPath != null, "flutter.sdk not set in local.properties"

	// Include Flutter's gradle build so its plugins are available declaratively
	includeBuild("${flutterSdkPath}/packages/flutter_tools/gradle")

	repositories {
		google()
		mavenCentral()
		gradlePluginPortal()
	}
}

plugins {
	id 'dev.flutter.flutter-plugin-loader' version '1.0.0'
	id 'com.android.application' version '8.11.1' apply false
	id 'org.jetbrains.kotlin.android' version '2.2.20' apply false
}

include ':app'
