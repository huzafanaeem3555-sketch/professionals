# Environment Variables for Service Connect Backend
PORT=7860
NODE_ENV=production
HOST=0.0.0.0

# Firebase Admin SDK
# Hugging Face Space deployment:
# - Use HF Secrets for these values
# - Set HOST=0.0.0.0 and PORT=7860
# Recommended: store the full service account JSON in FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative: base64-encoded service account JSON
FIREBASE_SERVICE_ACCOUNT_JSON_B64=
# Alternative: split credentials
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Fallback path for local development only
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=serviceconnect-dea35
FIREBASE_DATABASE_URL=https://serviceconnect-dea35-default-rtdb.firebaseio.com/
# Required for POST /api/auth/signin (password verify). Copy from:
# frontend/android/app/google-services.json → client[0].api_key[0].current_key
FIREBASE_API_KEY=AIzaSyAix8w3uQwdtBV0jYRSWoTBcQE_KYLPK2M

# Phone auth email domain (must match Flutter AuthService.phoneEmailDomain)
PHONE_EMAIL_DOMAIN=serviceconnect.pk

# Google Sign-In — Web client ID from google-services.json (oauth_client type 3)
GOOGLE_CLIENT_IDS=581660506706-rle7rsp19n1hc7l04tgp2dq53j0ijhb3.apps.googleusercontent.com

# ImgBB API (FREE image hosting - get key at https://api.imgbb.com)
# Register free at imgbb.com, go to API section, get your free key
IMGBB_API_KEY=your_imgbb_api_key_here

# Groq AI API Key (keep secret, do not commit real key)
GROQ_API_KEY=your_groq_api_key_here

# EasyPaisa Commission Account
EASYPAISA_ACCOUNT_NUMBER=03455876761
COMMISSION_RATE=0.10

# Security
JWT_SECRET=service-connect-secret-change-in-production
